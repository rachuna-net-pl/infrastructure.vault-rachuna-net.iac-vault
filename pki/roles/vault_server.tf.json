{
  "resource": {
    "vault_pki_secret_backend_role": {
      "vault_server": {
        "backend": "${var.pki_int_test_path}",
        "name": "vault-server",
        "ttl": "8760h",
        "max_ttl": "8760h",
        "allowed_domains": [
          "rachuna-net.pl",
          "vault-1022",
          "vault-1023",
          "vault-1024"
        ],
        "allow_subdomains": true,
        "allow_bare_domains": true,
        "allow_ip_sans": true,
        "allow_localhost": false,
        "server_flag": true,
        "client_flag": false,
        "key_type": "rsa",
        "key_bits": 4096,
        "organization": ["RACHUNA-NET.PL"],
        "ou": ["RACHUNA-NET.PL PKI"],
        "country": ["PL"],
        "locality": ["Toruń"]
      }
    }
  }
}
