{
  "resource": {
    "vault_pki_secret_backend_role": {
      "consul_server_test": {
        "backend": "${var.pki_int_test_path}",
        "name": "consul-server",
        "ttl": "31536000",
        "max_ttl": "31536000",
        "allowed_domains": [
          "rachuna-net.pl",
          "consul.rachuna-net.pl",
          "consul-1022",
          "consul-1023",
          "consul-1024"
        ],
        "allow_subdomains": true,
        "allow_bare_domains": true,
        "allow_ip_sans": true,
        "allow_localhost": false,
        "server_flag": true,
        "client_flag": false,
        "key_type": "rsa",
        "key_bits": 4096,
        "organization": ["RACHUNA-NET.PL"],
        "ou": ["RACHUNA-NET.PL PKI"],
        "country": ["PL"],
        "locality": ["Toruń"]
      }
    }
  }
}
