{
  "resource": {
    "vault_mount": {
      "pki_int_prod": {
        "path": "pki-int-prod",
        "type": "pki",
        "description": "Intermediate CA for rachuna-net.pl — production network",
        "max_lease_ttl_seconds": 315360000
      }
    },
    "vault_pki_secret_backend_intermediate_cert_request": {
      "pki_int_prod": {
        "backend": "${vault_mount.pki_int_prod.path}",
        "type": "internal",
        "common_name": "rachuna-net.pl Production Intermediate CA",
        "key_type": "rsa",
        "key_bits": 4096,
        "organization": "RACHUNA-NET.PL",
        "ou": "RACHUNA-NET.PL PKI",
        "country": "PL",
        "locality": "Toruń"
      }
    },
    "vault_pki_secret_backend_root_sign_intermediate": {
      "pki_int_prod": {
        "backend": "${vault_mount.pki_root.path}",
        "csr": "${vault_pki_secret_backend_intermediate_cert_request.pki_int_prod.csr}",
        "common_name": "rachuna-net.pl Production Intermediate CA",
        "ttl": "87600h",
        "use_csr_values": true
      }
    },
    "vault_pki_secret_backend_intermediate_set_signed": {
      "pki_int_prod": {
        "backend": "${vault_mount.pki_int_prod.path}",
        "certificate": "${vault_pki_secret_backend_root_sign_intermediate.pki_int_prod.certificate}"
      }
    },
    "vault_generic_endpoint": {
      "pki_int_prod_set_default": {
        "path": "${vault_mount.pki_int_prod.path}/config/issuers",
        "write_fields": ["default"],
        "data_json": "{\"default\": \"14a08e4a-674d-c6ae-fc58-dce414305cf6\"}"
      }
    },
    "vault_pki_secret_backend_config_urls": {
      "pki_int_prod": {
        "backend": "${vault_mount.pki_int_prod.path}",
        "issuing_certificates": [
          "https://vault-1022.rachuna-net.pl:8200/v1/pki-int-prod/ca"
        ],
        "crl_distribution_points": [
          "https://vault-1022.rachuna-net.pl:8200/v1/pki-int-prod/crl"
        ]
      }
    }
  }
}
